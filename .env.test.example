# RecruiterIQ — Playwright Test Credentials
# Copy this file to .env.test and fill in real values.
# The test account must be email-verified in Supabase.
#
# Required for auth & dashboard tests:
TEST_USER_EMAIL=test@yourdomain.com
TEST_USER_PASSWORD=your_secure_password

# Optional: second account on Agency plan (needed for ranking/team tests)
# If omitted, agency-plan tests will rely on client-side mocking.
TEST_AGENCY_EMAIL=agency@yourdomain.com
TEST_AGENCY_PASSWORD=your_secure_password
